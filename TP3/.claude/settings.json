{
  "cleanupPeriodDays": 30,
  "permissions": {
    "allow": [
      "Bash(python3:*)",
      "Bash(uvicorn:*)",
      "Bash(alembic:*)",
      "Bash(npm:*)",
      "Bash(pytest:*)",
      "Bash(pip:*)",
      "Bash(docker:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)"
    ],
    "ask": [
      "Bash(git push *)"
    ]
  },
  "model": "claude-sonnet-4-6",
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true
  }
}
